# PostgreSQL Database
POSTGRES_USER=indel
POSTGRES_PASSWORD=password # Change this for production or testing with stricter passwords
POSTGRES_DB=indel

# Docker Compose DB Variables
DB_USER=indel
DB_PASSWORD=password # Change this for production or testing with stricter passwords
DB_NAME=indel

# Kafka
KAFKA_BROKERS=localhost:9092

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY_HOURS=24

# Firebase
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ML Services
PREMIUM_ML_URL=http://localhost:9001
FRAUD_ML_URL=http://localhost:9002
FORECAST_ML_URL=http://localhost:9003

# External APIs
OPENWEATHER_API_KEY=your_openweather_api_key
OPENAQ_API_KEY=your_openaq_api_key

# Environment
INDEL_ENV=development
LOG_LEVEL=debug

# Network / API host configuration
# Use your machine LAN IP locally (example: 192.168.1.6) when testing from physical devices.
LAN_IP=192.168.1.6
HOST_IP=0.0.0.0
API_BASE_URL=http://192.168.1.6:8003/
PLATFORM_API_URL=http://192.168.1.6:8004
VITE_PLATFORM_API_URL=http://192.168.1.6:8004
VITE_INSURER_API_URL=http://192.168.1.6:8004
