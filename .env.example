# InDel Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# Database
DB_PASSWORD=password
POSTGRES_PASSWORD=password

# Razorpay Payment Gateway
# Get these from: https://dashboard.razorpay.com/app/settings/api-keys
RAZORPAY_API_KEY=rzp_test_your_key_here
RAZORPAY_API_SECRET=your_secret_here
RAZORPAY_MODE=test

# Environment (production or development)
INDEL_ENV=production

# Kafka
KAFKA_BROKERS=kafka:9092
